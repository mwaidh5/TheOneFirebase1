rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- Helper Functions ---
    
    // Check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if the user has a specific role (stored in their user document)
    function hasRole(role) {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    // Check if the user is an Admin
    function isAdmin() {
      return hasRole('Admin');
    }
    
    // Check if the user is a Coach
    function isCoach() {
      return hasRole('Coach');
    }

    // Check if the user is accessing their own document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    // 1. Users Collection
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin() || isCoach();
      allow create: if isAuthenticated();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // 2. Courses Collection
    match /courses/{courseId} {
      allow read: if true;
      allow create, update, delete: if isCoach() || isAdmin();
    }

    // 3. Media Assets (Library)
    match /media/{mediaId} {
      allow read: if true;
      allow write: if isCoach() || isAdmin();
    }

    // 4. Exercise & Workout Libraries (Templates)
    match /exercises/{exerciseId} {
        allow read: if true;
        allow write: if isCoach() || isAdmin();
    }
    
    match /workouts/{workoutId} {
        allow read: if true;
        allow write: if isCoach() || isAdmin();
    }
    
    match /mealplans/{planId} {
        allow read: if true;
        allow write: if isCoach() || isAdmin();
    }

    // 5. Custom Course Requests
    match /custom_requests/{requestId} {
      allow create: if isAuthenticated();
      allow read, update: if isAuthenticated() && (resource.data.athleteId == request.auth.uid || isCoach() || isAdmin());
      allow delete: if isAdmin();
    }

    // 6. Conversations & Messages
    match /conversations/{conversationId} {
      allow read: if isAuthenticated() && (
        request.auth.uid in resource.data.participants || 
        hasRole('Admin') || 
        hasRole('Support')
      );
      
      allow create: if isAuthenticated() && (
        request.auth.uid in request.resource.data.participants
      );
      
      allow update: if isAuthenticated() && (
        request.auth.uid in resource.data.participants || 
        hasRole('Admin') || 
        hasRole('Support')
      );

      match /messages/{messageId} {
        allow read, list: if isAuthenticated() && (
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants || 
          hasRole('Admin') || 
          hasRole('Support')
        );
        
        allow create: if isAuthenticated() && (
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants || 
          hasRole('Admin') || 
          hasRole('Support')
        );
      }
    }

    // 7. Custom Disciplines Configuration
    match /custom_disciplines/{docId} {
      allow read: if true;
      allow write: if isAdmin() || isCoach();
    }

    // Default deny all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
