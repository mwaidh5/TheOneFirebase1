rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- Helper Functions ---

    // Check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if the user has a specific role (stored in their user document)
    function hasRole(role) {
      return isAuthenticated() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    // Check if the user is an Admin
    function isAdmin() {
      return hasRole('Admin');
    }

    // Check if the user is a Coach
    function isCoach() {
      return hasRole('Coach');
    }

    // Check if the user is accessing their own document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    // 1. Users Collection
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin() || isCoach();

      // FIX #1: Force CLIENT role on create — prevents self-assigning Admin/Coach
      allow create: if isAuthenticated()
        && request.auth.uid == userId
        && request.resource.data.role == 'Client'
        && request.resource.data.id == request.auth.uid;

      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      // Allow access to progress subcollection
      match /progress/{progressId} {
        allow read, write: if isOwner(userId) || isAdmin() || isCoach();
      }
    }

    // 2. Courses Collection
    match /courses/{courseId} {
      allow read: if true;
      allow create, update, delete: if isCoach() || isAdmin();
    }

    // 3. Media Assets (Library)
    match /media/{mediaId} {
      allow read: if true;
      allow write: if isCoach() || isAdmin();
    }

    // 4. Exercise & Workout Libraries (Templates)
    match /exercises/{exerciseId} {
      allow read: if true;
      allow write: if isCoach() || isAdmin();
    }

    match /workouts/{workoutId} {
      allow read: if true;
      allow write: if isCoach() || isAdmin();
    }

    match /mealplans/{planId} {
      allow read: if true;
      allow write: if isCoach() || isAdmin();
    }

    // 5. Custom Course Requests
    // FIX #2: Validate field lengths to prevent spam / database bloat
    match /custom_requests/{requestId} {
      allow create: if isAuthenticated()
        && request.resource.data.goal.size() < 500
        && request.resource.data.athleteName.size() < 100
        && request.resource.data.sport.size() < 100;

      allow read, update: if isAuthenticated() && (
        resource.data.athleteId == request.auth.uid ||
        isCoach() ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // 6. Conversations & Messages
    match /conversations/{conversationId} {
      allow read: if isAuthenticated() && (
        request.auth.uid in resource.data.participants ||
        hasRole('Admin') ||
        hasRole('Support')
      );

      allow create: if isAuthenticated() &&
        request.auth.uid in request.resource.data.participants;

      allow update: if isAuthenticated() && (
        request.auth.uid in resource.data.participants ||
        hasRole('Admin') ||
        hasRole('Support')
      );

      // FIX #3: Limit message text length to prevent message spam / DB bloat
      match /messages/{messageId} {
        allow read, list: if isAuthenticated() && (
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants ||
          hasRole('Admin') ||
          hasRole('Support')
        );

        allow create: if isAuthenticated()
          && (
            request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants ||
            hasRole('Admin') ||
            hasRole('Support')
          )
          && request.resource.data.text.size() <= 2000;  // Max 2000 chars per message
      }
    }

    // 7. Custom Disciplines Configuration
    match /custom_disciplines/{docId} {
      allow read: if true;
      allow write: if isAdmin() || isCoach();
    }

    // 8. Site Settings
    // FIX #4: Was open to public (!). Now restricted to Admin only.
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Default deny all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
